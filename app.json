{
  "expo": {
    "name": "TaroCarta",
    "slug": "tarocarta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hgbayraktar.tarocarta",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use this to show you relevant ads and improve your experience."
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1924459116813725~3209600388",
          "iosAppId": "ca-app-pub-1924459116813725~3209600388"
        }
      ]
    ],
    "scheme": "tarocarta",
    "experiments": {
      "typedRoutes": true
    }
  }
}
